{
  "name": "pwai-workspace",
  "private": true,
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend"
  },
  "dependencies": {
    "firebase": "^12.9.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
